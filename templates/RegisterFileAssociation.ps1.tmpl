# =============================================================================
# RegisterFileAssociation — generated by New-MsixStandardScript
# Registers a host-side file association under HKCU so explorer launches the
# packaged app's AppExecutionAlias for the configured extensions.
# =============================================================================
# Replaced placeholders:
#   <#PARAM:Extensions#>   Comma-separated extensions (.txt, .csv …)
#   <#PARAM:ProgId#>       ProgId to register (e.g. ContosoApp.Document)
#   <#PARAM:Target#>       AppExecutionAlias or full path
#   <#PARAM:Arguments#>    Optional arguments passed before "%1"
# =============================================================================

$ErrorActionPreference = 'SilentlyContinue'

$exts     = @('<#PARAM:Extensions#>'.Split(',') | ForEach-Object { $_.Trim() } | Where-Object { $_ })
$progId   = '<#PARAM:ProgId#>'
$target   = '<#PARAM:Target#>'
$args     = '<#PARAM:Arguments#>'

$openCmd = if ($args) { "`"$target`" $args `"%1`"" } else { "`"$target`" `"%1`"" }

# Class registration under HKCU
$progKey = "HKCU:\Software\Classes\$progId"
New-Item -ItemType Directory -Path "$progKey\shell\open\command" -Force | Out-Null
Set-ItemProperty -Path "$progKey\shell\open\command" -Name '(default)' -Value $openCmd

foreach ($ext in $exts) {
    if (-not $ext.StartsWith('.')) { $ext = ".$ext" }
    $extKey = "HKCU:\Software\Classes\$ext"
    New-Item -ItemType Directory -Path $extKey -Force | Out-Null
    Set-ItemProperty -Path $extKey -Name '(default)' -Value $progId
}
