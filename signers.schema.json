{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/sanderdewit/msix/main/signers.schema.json",
  "title": "MSIX trusted-publisher allowlist",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "publishers"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "description": {
      "type": "string"
    },
    "publishers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "subjectPrefix",
          "description"
        ],
        "properties": {
          "subjectPrefix": {
            "type": "string",
            "pattern": "^CN=.+,$"
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "addedBy": {
            "type": "string"
          },
          "addedAt": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
          },
          "thumbprint": {
            "type": "string",
            "pattern": "^(?:[0-9A-Fa-f]\\s*){40}$"
          }
        }
      }
    }
  }
}
