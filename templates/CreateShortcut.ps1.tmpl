# =============================================================================
# CreateShortcut — generated by New-MsixStandardScript
# Runs from PSF startScript on first launch and creates a .lnk on the user's
# desktop / start menu pointing at the packaged AppExecutionAlias.
# =============================================================================
# Replaced placeholders:
#   <#PARAM:DisplayName#>      Title shown on the shortcut
#   <#PARAM:Target#>            Alias (e.g. contosoexpenses.exe) or full path
#   <#PARAM:Arguments#>         Optional CLI arguments
#   <#PARAM:WorkingDirectory#>  Default working directory
#   <#PARAM:IconPath#>          Path to an .ico (resolved via %LOCALAPPDATA%)
#   <#PARAM:Location#>          'Desktop' | 'StartMenu' | 'Both'
# =============================================================================

$ErrorActionPreference = 'SilentlyContinue'

$displayName     = '<#PARAM:DisplayName#>'
$target          = '<#PARAM:Target#>'
$arguments       = '<#PARAM:Arguments#>'
$workingDir      = '<#PARAM:WorkingDirectory#>'
$iconPath        = '<#PARAM:IconPath#>'
$location        = '<#PARAM:Location#>'

$shell = New-Object -ComObject WScript.Shell

function _Make-Shortcut {
    param([string]$LnkPath)
    $sc                  = $shell.CreateShortcut($LnkPath)
    $sc.TargetPath       = $target
    if ($arguments)  { $sc.Arguments        = $arguments }
    if ($workingDir) { $sc.WorkingDirectory = $workingDir }
    if ($iconPath -and (Test-Path $iconPath)) { $sc.IconLocation = $iconPath }
    $sc.Save()
}

if ($location -in 'Desktop','Both') {
    $desktop = [Environment]::GetFolderPath('Desktop')
    _Make-Shortcut -LnkPath (Join-Path $desktop "$displayName.lnk")
}
if ($location -in 'StartMenu','Both') {
    $start = Join-Path ([Environment]::GetFolderPath('Programs')) 'Contoso'
    New-Item -ItemType Directory -Path $start -Force | Out-Null
    _Make-Shortcut -LnkPath (Join-Path $start "$displayName.lnk")
}
