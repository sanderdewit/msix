# =============================================================================
# CopyIconToAppData — generated by New-MsixStandardScript
# Copies bundled icon(s) out of the package into %APPDATA% so shortcut .lnk
# files (which can't reference the versioned WindowsApps install path) keep
# working across package updates.
# =============================================================================
# Replaced placeholders:
#   <#PARAM:SourceFiles#>   Comma-separated list of package-relative icons
#   <#PARAM:DestSubfolder#> Subfolder under %APPDATA% (default: '<vendor>')
# =============================================================================

$ErrorActionPreference = 'SilentlyContinue'

$sources       = @('<#PARAM:SourceFiles#>'.Split(',') | ForEach-Object { $_.Trim() } | Where-Object { $_ })
$destSubfolder = '<#PARAM:DestSubfolder#>'

$dest = Join-Path $env:APPDATA $destSubfolder
New-Item -ItemType Directory -Path $dest -Force | Out-Null

foreach ($src in $sources) {
    if (Test-Path $src) {
        Copy-Item $src $dest -Force
    }
}
