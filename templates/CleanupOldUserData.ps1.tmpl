# =============================================================================
# CleanupOldUserData — generated by New-MsixStandardScript
# Idempotent cleanup of user-state directories left behind by a legacy
# installation, so the packaged app starts from a known-good state.
# =============================================================================
# Replaced placeholders:
#   <#PARAM:Paths#>           Comma-separated list of paths to remove
#                              (env var expansion supported, e.g. %APPDATA%\Old)
#   <#PARAM:RegistryKeys#>    Comma-separated registry keys to remove
#                              (HKCU:\… or HKLM:\…)
#   <#PARAM:OnlyOlderThanDays#>  Skip paths newer than N days; 0 = remove all
# =============================================================================

$ErrorActionPreference = 'SilentlyContinue'

$paths        = @('<#PARAM:Paths#>'.Split(',') | ForEach-Object { [Environment]::ExpandEnvironmentVariables($_.Trim()) } | Where-Object { $_ })
$regKeys      = @('<#PARAM:RegistryKeys#>'.Split(',') | ForEach-Object { $_.Trim() } | Where-Object { $_ })
$ageThreshold = [int]'<#PARAM:OnlyOlderThanDays#>'

$cutoff = if ($ageThreshold -gt 0) { (Get-Date).AddDays(-$ageThreshold) } else { Get-Date }

foreach ($p in $paths) {
    if (-not (Test-Path $p)) { continue }
    $info = Get-Item $p -Force -ErrorAction SilentlyContinue
    if ($ageThreshold -gt 0 -and $info.LastWriteTime -ge $cutoff) { continue }
    Remove-Item $p -Recurse -Force -ErrorAction SilentlyContinue
}
foreach ($k in $regKeys) {
    if (Test-Path $k) {
        Remove-Item $k -Recurse -Force -ErrorAction SilentlyContinue
    }
}
