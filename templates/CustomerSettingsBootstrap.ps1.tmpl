# =============================================================================
# CustomerSettingsBootstrap — generated by New-MsixStandardScript
# Reads a baked-in JSON blob (parameterised at script-generation time) and
# writes each property under a configured HKCU key. Idempotent: existing values
# are not overwritten unless -Force was set when the script was generated.
# =============================================================================
# Replaced placeholders:
#   <#PARAM:Settings#>     JSON object — flat key/value pairs
#   <#PARAM:HivePath#>     Target HKCU path (e.g. HKCU:\Software\Contoso\App)
#   <#PARAM:Overwrite#>    'true' or 'false'
# =============================================================================

$ErrorActionPreference = 'SilentlyContinue'

$json     = '<#PARAM:Settings#>'
$hive     = '<#PARAM:HivePath#>'
$overwrite = ('<#PARAM:Overwrite#>' -eq 'true')

if ([string]::IsNullOrWhiteSpace($json)) { return }
$settings = $json | ConvertFrom-Json

if (-not (Test-Path $hive)) {
    New-Item -ItemType Directory -Path $hive -Force | Out-Null
}

foreach ($name in $settings.PSObject.Properties.Name) {
    $value = $settings.$name
    $existing = (Get-ItemProperty -Path $hive -Name $name -ErrorAction SilentlyContinue).$name
    if (-not $overwrite -and $null -ne $existing) { continue }
    Set-ItemProperty -Path $hive -Name $name -Value $value -Type String
}
